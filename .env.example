# =====================================================================
#  AI_brief 파이프라인 비밀값 — 이 파일을 복사해 `.env` 로 저장하고 채운다.
#  코드/저장소에는 절대 실제 값을 남기지 않는다. (.env 는 .gitignore 처리됨)
#  GitHub Actions 로 운영할 때는 동일 키들을 "Repository Secrets" 에 등록한다.
# =====================================================================

# --- Claude (텍스트 요약·분류) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Gemini (유튜브 영상 네이티브 URL 분석) ---
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- YouTube Data API (선택: 영상 길이/메타데이터 정확도 향상) ---
# 없어도 채널 RSS 로 신규 영상 "탐지" 는 동작한다. 단, 예산(분량) 판정 정확도는 떨어진다.
YOUTUBE_API_KEY=

# --- 카카오 "나에게 보내기" (memo/send) ---
# REST API 키 = 카카오 개발자 콘솔의 "REST API 키" (= OAuth client_id)
KAKAO_REST_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# refresh token(약 2개월) — 최초 1회 발급 후 저장. README "카카오 토큰 발급" 참고.
KAKAO_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# access token(약 6시간) — 비워도 됨. 만료 시 refresh token 으로 자동 재발급한다.
KAKAO_ACCESS_TOKEN=
# 클라이언트 시크릿 — 앱에서 '클라이언트 시크릿'을 활성화한 경우에만 필요(REST API 키 발급 시 기본 ON).
# [플랫폼 키 > REST API 키 수정 > 클라이언트 시크릿]에서 코드 확인. 미사용(OFF) 시 비워둔다.
KAKAO_CLIENT_SECRET=

# --- 운영 토글 ---
# true 면 실제 전송 안 하고 콘솔/파일로만 출력(기본 안전값). 실제 발송은 false.
DRY_RUN=true
