# ── 비밀값: 절대 커밋 금지 (플레이스홀더 .env.example 만 허용) ──
.env
.env.*
*.env
!.env.example
secrets/
*.pem
*.key
*.p12
credentials*.json
service-account*.json

# ── 백업/임시 변형(실수로 키가 남을 수 있는 파일 클래스 전체 차단) ──
*.bak
*.backup
*.orig
*.save
*~

# ── 상태 디렉터리 전체 제외(토큰·dedup·이력·pending·.tmp 등) — .gitkeep 만 허용 ──
state/*
!state/.gitkeep

# ── 생성물(dry-run 출력 / 로컬 HTML 빌드) ──
out/
public/
*.log

# ── 파이썬 ──
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
